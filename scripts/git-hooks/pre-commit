#!/usr/bin/env bash
set -euo pipefail

# say <level> <message> — prints with gum if installed, plain otherwise.
# Levels match gum's: info, warn, error, debug.
if command -v gum >/dev/null 2>&1; then
  say() { gum log --structured --level "$1" --prefix "pre-commit" "$2" >&2; }
else
  say() { echo "[pre-commit][$1] $2" >&2; }
fi

existing=()
while IFS= read -r f; do
  [ -n "$f" ] && [ -f "$f" ] && existing+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ "${#existing[@]}" -eq 0 ]; then
  say info "no Go files staged, skipping"
  exit 0
fi

# Mirror the conform.nvim chain so commits look identical to nvim's
# format-on-save: gofumpt → goimports-reviser → golines. Falls back to
# gofmt when none of the three is installed (the toolchain ships gofmt).
ran_any=0

if command -v gofumpt >/dev/null 2>&1; then
  say info "gofumpt -w ${#existing[@]} file(s)"
  gofumpt -w "${existing[@]}"
  ran_any=1
fi

if command -v goimports-reviser >/dev/null 2>&1; then
  say info "goimports-reviser ${#existing[@]} file(s)"
  # goimports-reviser prints "Paths: […]" / "Processing …" via Go's log
  # package on stderr for every file. We want them rendered through the
  # same gum-styled debug stream as the rest of the hook, but the
  # previous `2> >(while read; do say; done)` setup ran the gum calls
  # inside a process substitution that shared the tty with the still-
  # running goimports-reviser. The concurrent gum spawns each fired
  # OSC/CPR queries against the terminal; the terminal's responses
  # leaked into stdout as raw escape sequences (`^[]11;rgb:…`,
  # `^[[29;…R`) between batches.
  #
  # Two-phase fix: capture all stderr first (sequentially, no concurrent
  # subshells), let goimports-reviser fully release the tty, then walk
  # the buffered lines through gum from the main shell. Strip the
  # leading "YYYY/MM/DD HH:MM:SS " timestamp since gum adds its own.
  # Anything that doesn't match the noise pattern is a real problem and
  # goes through `say error`.
  ts_re='^[0-9]{4}/[0-9]{2}/[0-9]{2} [0-9:]+ '
  noise_re='(Paths:|Processing )'
  collected=""
  for f in "${existing[@]}"; do
    # 2>&1 >/dev/null swaps fds so the command substitution captures
    # stderr (the log lines) and discards stdout. `|| true` prevents
    # set -e from aborting the hook when goimports-reviser exits non-
    # zero on a file it cannot rewrite — we still want to report it.
    err=$(goimports-reviser -output file "$f" 2>&1 >/dev/null) || true
    if [ -n "$err" ]; then
      collected+="${err}"$'\n'
    fi
  done
  if [ -n "$collected" ]; then
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      stripped="${line}"
      [[ "$stripped" =~ $ts_re ]] && stripped="${stripped#$BASH_REMATCH}"
      if [[ "$stripped" =~ ^$noise_re ]]; then
        say debug "$stripped"
      else
        say error "$stripped"
      fi
    done <<<"$collected"
  fi
  ran_any=1
fi

if command -v golines >/dev/null 2>&1; then
  say info "golines -w ${#existing[@]} file(s)"
  golines -w "${existing[@]}"
  ran_any=1
fi

if [ "$ran_any" -eq 0 ]; then
  say warn "none of gofumpt/goimports-reviser/golines installed, falling back to gofmt"
  gofmt -w "${existing[@]}"
fi

git add "${existing[@]}"
