#!/usr/bin/env bash
set -euo pipefail

# say <level> <message> — prints with gum if installed, plain otherwise.
# Levels match gum's: info, warn, error, debug.
if command -v gum >/dev/null 2>&1; then
  say() { gum log --structured --level "$1" --prefix "pre-commit" "$2" >&2; }
else
  say() { echo "[pre-commit][$1] $2" >&2; }
fi

existing=()
while IFS= read -r f; do
  [ -n "$f" ] && [ -f "$f" ] && existing+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ "${#existing[@]}" -eq 0 ]; then
  say info "no Go files staged, skipping"
  exit 0
fi

# Mirror the conform.nvim chain so commits look identical to nvim's
# format-on-save: gofumpt → goimports-reviser → golines. Falls back to
# gofmt when none of the three is installed (the toolchain ships gofmt).
ran_any=0

if command -v gofumpt >/dev/null 2>&1; then
  say info "gofumpt -w ${#existing[@]} file(s)"
  gofumpt -w "${existing[@]}"
  ran_any=1
fi

if command -v goimports-reviser >/dev/null 2>&1; then
  say info "goimports-reviser ${#existing[@]} file(s)"
  # goimports-reviser prints "Paths: […]" / "Processing …" via Go's log
  # package on stderr for every file. Re-emit those through `say debug`
  # so they ride the same gum-styled stream as the rest of the hook
  # (and respect GUM_LOG_LEVEL — hidden by default, visible when the
  # user opts into debug). Strip the leading "YYYY/MM/DD HH:MM:SS "
  # timestamp since gum adds its own. Anything else on stderr is a real
  # problem and goes through `say error` at the matching level.
  ts_re='^[0-9]{4}/[0-9]{2}/[0-9]{2} [0-9:]+ '
  noise_re='(Paths:|Processing )'
  for f in "${existing[@]}"; do
    goimports-reviser -output file "$f" >/dev/null 2> >(
      while IFS= read -r line; do
        stripped="${line}"
        [[ "$stripped" =~ $ts_re ]] && stripped="${stripped#$BASH_REMATCH}"
        if [[ "$stripped" =~ ^$noise_re ]]; then
          say debug "$stripped"
        else
          say error "$stripped"
        fi
      done
    )
  done
  ran_any=1
fi

if command -v golines >/dev/null 2>&1; then
  say info "golines -w ${#existing[@]} file(s)"
  golines -w "${existing[@]}"
  ran_any=1
fi

if [ "$ran_any" -eq 0 ]; then
  say warn "none of gofumpt/goimports-reviser/golines installed, falling back to gofmt"
  gofmt -w "${existing[@]}"
fi

git add "${existing[@]}"
